# TokenMP v3 Auth Service — example environment.
#
# Copy to .env and fill with non-production values for local development.
# Never commit a real .env. No production credentials are shipped here.

# Required. Single PostgreSQL connection URL. Use a dedicated database named
# tokenmp_auth. Avoid composing the URL from multiple parts to prevent
# leaking fragments in logs or error messages. The value below is a
# placeholder for a confirmed shared dev/preview database; do NOT install or
# start PostgreSQL locally — migrations and integration tests run only in CI.
AUTH_DATABASE_URL=postgres://tokenmp:tokenmp@localhost:5432/tokenmp_auth?sslmode=disable

# Required. Ed25519 JWT key pair file paths. PEM-encoded PKCS8 private key and
# PKIX public key. The service fails fast at startup if the files are missing
# or do not parse as valid Ed25519 PEM; errors never echo the key contents or
# the file paths. The private key MUST be kept secret; if it is compromised an
# attacker can forge valid access tokens until the key is rotated (consumers
# only need the public key to verify tokens). Generate locally for dev with:
#
#   openssl genpkey -algorithm Ed25519 -out auth_jwt_private.pem
#   openssl pkey -in auth_jwt_private.pem -pubout -out auth_jwt_public.pem
#
# Do NOT commit generated key files. Tests generate an in-memory key pair and
# never read these files. The Docker runtime image does NOT contain keys;
# deployments MUST mount the key files at runtime (see Dockerfile + ADR 0005).
AUTH_JWT_PRIVATE_KEY_FILE=./config/auth_jwt_private.pem
AUTH_JWT_PUBLIC_KEY_FILE=./config/auth_jwt_public.pem

# Optional. JWT issuer and audience claims. Defaults: tokenmp-auth / tokenmp-web.
# Access tokens carry iss/aud/sub/jti/iat/nbf/exp + role + token_version.
AUTH_JWT_ISSUER=tokenmp-auth
AUTH_JWT_AUDIENCE=tokenmp-web

# Optional. Access token lifetime (Ed25519/EdDSA JWT). Default: 15m.
AUTH_JWT_ACCESS_TOKEN_TTL=15m

# Optional. Refresh token lifetime (opaque 32-byte base64url token; DB stores
# only its SHA-256 hash). Default: 30d. Must be greater than the access TTL.
AUTH_JWT_REFRESH_TOKEN_TTL=720h

# Optional. HTTP listen address. Default: :8080
AUTH_HTTP_ADDR=:8080

# Optional. Log level: debug|info|warn|error. Default: info
AUTH_LOG_LEVEL=info

# Optional. Log format: json|text. Default: json
AUTH_LOG_FORMAT=json

# Optional. Graceful shutdown budget. Default: 30s
AUTH_SHUTDOWN_TIMEOUT=30s

# Optional. Database pool tuning. Defaults shown.
AUTH_DB_MAX_OPEN_CONNS=25
AUTH_DB_MAX_IDLE_CONNS=5
AUTH_DB_CONN_MAX_LIFETIME=30m

# Optional. Address used only by the in-image healthcheck binary. Default
# below matches AUTH_HTTP_ADDR when it is :8080. Override when binding to a
# different address or a unix socket.
AUTH_HEALTHCHECK_ADDR=http://127.0.0.1:8080/healthz
