      "Capability": {
        "Require": ["chat", "streaming"],
        "Deny": []
      },
      "Thinking": {
        "Supported": true,
        "DefaultEffort": "medium",
        "EffortMapping": {
          "none": "none",
          "minimal": "minimal",
          "low": "low",
          "medium": "medium",
          "high": "high",
          "xhigh": "high",
          "max": "high"
        },
        "BudgetMapping": {
          "low": 2000,
          "medium": 4000,
          "high": 8000
        },
        "MinBudgetToken": 0,
        "MaxBudgetToken": 8000
      },
      "Request": {
        "AllowedHeaders": ["Content-Type", "Accept"],
        "AllowedQuery": [],
        "Rules": []
      },
      "Response": {
        "Rules": [
          {
            "ID": "resp-429",
            "Priority": 10,
            "Match": {
              "HTTPStatuses": [429]
            },
            "Output": {
              "HTTPStatus": 429,
              "ErrorCode": "rate_limited",
              "ErrorType": "rate_limited",
              "Message": "upstream rate limited"
            }
          }
        ]
      },
      "Retry": {
        "MaxTotalAttempts": 3,
        "MaxSameTargetAttempts": 2,
