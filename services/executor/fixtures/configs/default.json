        "Rules": [
          {
            "ID": "retry-429",
            "Priority": 10,
            "HTTPStatuses": [429],
            "Action": "next_credential"
          },
          {
            "ID": "retry-5xx",
            "Priority": 20,
            "HTTPStatuses": [500, 502, 503, 504],
            "Action": "next_route"
          }
        ]
      },
      "Timeout": {
        "RequestTimeout": "120s",
        "TTFTTimeout": "20s",
